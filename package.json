{
  "name": "omnis-desktop",
  "version": "2.2.9",
  "description": "Omnis Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "build": {
    "appId": "com.omnis.desktop",
    "productName": "Omnis",
    "compression": "normal",
    "files": [
      "main.js",
      "package.json",
      "index.html",
      "lib/**/*",
      "systems/**/*",
      "assets/**/*",
      "omnis_dashboard.py",
      "*.xml",
      "api_error.json",
      "!dist",
      "!node_modules/electron/**",
      "!node_modules/electron-builder/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "tahcool",
      "repo": "Omnis-Desktop-Application"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/images/omnis-notification-icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Omnis Salestrack",
      "artifactName": "Omnis_Setup_${version}.exe"
    }
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^39.2.5",
    "electron-builder": "^26.4.0",
    "expo": "~54.0.21",
    "expo-device": "^8.0.10",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "better-sqlite3": "^12.6.2",
    "electron-log": "^5.4.3",
    "electron-store": "^9.0.0",
    "electron-updater": "^6.8.3",
    "qrcode": "^1.5.4",
    "whatsapp-web.js": "^1.34.7"
  }
}
