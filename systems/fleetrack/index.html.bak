                      </div>
                  </div>

                  <div style="display: flex; align-items: center; justify-content: space-between; padding: 16px; background: #f8fafc; border-radius: 12px; opacity: 0.6; cursor: not-allowed;">
                      <div>
                          <div style="font-weight: 700; color: #1e293b;">Desktop Notifications</div>
                          <div style="font-size: 12px; color: #64748b;">Get browser alerts for new breakdowns.</div>
                      </div>
                      <span style="font-size: 11px; font-weight: 700; color: #64748b; background: #e2e8f0; padding: 4px 8px; border-radius: 4px;">COMING SOON</span>
                  </div>
              </div>
          </div>
