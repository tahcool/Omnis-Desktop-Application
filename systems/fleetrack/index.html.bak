          <div>
            <label style="display:block; font-size:11px; font-weight:700; color:#64748b; margin-bottom:6px; text-transform:uppercase; letter-spacing:0.05em;">Out ETA (Ready Date)</label>
            <input type="date" id="db-edit-out-eta" style="width:100%; height:38px; padding:0 10px; border:1px solid #cbd5e1; border-radius:8px; font-size:13px;">
