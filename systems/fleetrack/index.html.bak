      <div style="padding:20px; overflow-y:auto; flex:1; background:#ffffff;">
        
        <!-- Metadata Context (Subtle Top Bar) -->
        <div style="display:grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap:12px; background:#f8fafc; padding:10px 16px; border-radius:8px; border:1px solid #f1f5f9; margin-bottom:20px;">
          <div><label style="display:block; font-size:9px; font-weight:700; color:#94a3b8; text-transform:uppercase;">Customer</label><input type="text" id="db-edit-customer" readonly style="border:none; background:transparent; font-size:12px; font-weight:600; width:100%; color:#475569;"></div>
          <div><label style="display:block; font-size:9px; font-weight:700; color:#94a3b8; text-transform:uppercase;">Machine</label><input type="text" id="db-edit-machine" readonly style="border:none; background:transparent; font-size:12px; font-weight:600; width:100%; color:#475569;"></div>
          <div><label style="display:block; font-size:9px; font-weight:700; color:#94a3b8; text-transform:uppercase;">Serial No</label><input type="text" id="db-edit-sn" readonly style="border:none; background:transparent; font-size:12px; font-weight:600; width:100%; color:#475569;"></div>
          <div><label style="display:block; font-size:9px; font-weight:700; color:#94a3b8; text-transform:uppercase;">Fleet No</label><input type="text" id="db-edit-fleet" readonly style="border:none; background:transparent; font-size:12px; font-weight:600; width:100%; color:#475569;"></div>
        </div>

        <!-- ROW 1: PRIMARY DATES -->
        <div style="display:grid; grid-template-columns: 1fr 1fr 1fr; gap:16px; margin-bottom:16px;">
          <div>
            <label for="db-edit-date" style="display:block; font-size:11px; font-weight:700; color:#64748b; margin-bottom:6px; text-transform:uppercase; letter-spacing:0.05em;">Breakdown Date</label>
            <input type="date" id="db-edit-date" style="width:100%; height:38px; padding:0 10px; border:1px solid #cbd5e1; border-radius:8px; font-size:13px;">
          </div>
          <div>
            <label for="db-edit-end-date" style="display:block; font-size:11px; font-weight:700; color:#64748b; margin-bottom:6px; text-transform:uppercase; letter-spacing:0.05em;">End Date</label>
            <input type="date" id="db-edit-end-date" style="width:100%; height:38px; padding:0 10px; border:1px solid #cbd5e1; border-radius:8px; font-size:13px;">
          </div>
