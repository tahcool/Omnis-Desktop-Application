      <!-- JOB CARDS VIEW -->
      <div id="view-job-cards" class="view-page hidden">
        <div style="background:var(--bg-card);border-radius:16px;padding:24px;box-shadow:0 2px 8px rgba(0,0,0,0.08);">
          <div
            style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;padding-bottom:16px;border-bottom:2px solid #e5e7f0;">
            <div>
              <div style="display:flex;align-items:center;gap:12px;margin-bottom:8px;">
                <img src="../../assets/images/omnis-notification-icon.png" alt="Omnis" style="height:32px;"
                  onerror="this.style.display='none'">
                <h1 style="font-size:22px;font-weight:700;margin:0;">Job Cards</h1>
              </div>
              <div style="font-size:12px;color:#64748b;">Manage field service jobs and weekly reminders.</div>
            </div>
            <div style="display:flex;align-items:center;gap:12px;">
              <button id="btn-new-job-card"
                style="background:#ef4444;color:#ffffff;padding:8px 16px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:6px;box-shadow:0 1px 2px rgba(0,0,0,0.1); border:none; outline:none;">
                <span>+</span>
                <span>New Job Card</span>
              </button>
              <div
                style="background:#000;color:#fff;padding:8px 16px;border-radius:8px;font-size:13px;font-weight:700;">
                Today's Jobs: <span id="job-count-today">0</span>
              </div>
            </div>
          </div>

          <!-- KPI Summary Row -->
          <div id="jc-kpi-row"
            style="display:grid; grid-template-columns: repeat(4, 1fr); gap:16px; margin-bottom:24px;">
            <div class="jc-kpi-card">
              <div class="jc-kpi-label">Total Job Cards</div>
              <div id="jc-stat-total" class="jc-kpi-value">0</div>
              <div class="jc-kpi-sub">Total in current view</div>
            </div>
            <div class="jc-kpi-card accent-red">
              <div class="jc-kpi-label">Open / Active</div>
              <div id="jc-stat-open" class="jc-kpi-value" style="color:#ef4444;">0</div>
              <div class="jc-kpi-sub">Requires immediate attention</div>
            </div>
            <div class="jc-kpi-card">
              <div class="jc-kpi-label">Awaiting Parts</div>
              <div id="jc-stat-parts" class="jc-kpi-value">0</div>
              <div class="jc-kpi-sub">Pending procurement</div>
            </div>
            <div class="jc-kpi-card">
              <div class="jc-kpi-label">Completed Today</div>
              <div id="jc-stat-today" class="jc-kpi-value">0</div>
              <div class="jc-kpi-sub">Updated in real-time</div>
            </div>
          </div>

          <!-- Weekly Calendar Strip -->
          <div id="job-calendar-strip" class="calendar-strip">
            <!-- Rendered by JS -->
          </div>

          <!-- Table -->
          <div style="overflow-x:auto;">
            <table id="job-card-table"
              style="width:100%;border-collapse:collapse;font-size:11px;table-layout:auto;border:1px solid #e5e7f0;">
              <thead>
                <tr style="background:#f02510;color:#ffffff !important;">
                  <th
                    style="padding:10px 8px;text-align:left;font-weight:700;border-right:1px solid rgba(255,255,255,0.2);color:#ffffff !important;">
                    Job Card ID</th>
                  <th
                    style="padding:10px 8px;text-align:left;font-weight:700;border-right:1px solid rgba(255,255,255,0.2);color:#ffffff !important;">
                    Customer</th>
                  <th
                    style="padding:10px 8px;text-align:left;font-weight:700;border-right:1px solid rgba(255,255,255,0.2);color:#ffffff !important;">
                    Machine / Model</th>
                  <th
                    style="padding:10px 8px;text-align:left;font-weight:700;border-right:1px solid rgba(255,255,255,0.2);color:#ffffff !important;">
                    Technician</th>
                  <th
                    style="padding:10px 8px;text-align:left;font-weight:700;border-right:1px solid rgba(255,255,255,0.2);color:#ffffff !important;">
                    Status</th>
                  <th style="padding:10px 8px;text-align:left;font-weight:700;color:#ffffff !important;">
                    Created</th>
                </tr>
              </thead>
              <tbody id="job-card-tbody">
                <tr>
                  <td colspan="6" style="padding:40px;text-align:center;color:#94a3b8;font-size:12px;">
                    Loading job cards...
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- About View -->
      <div id="view-about" class="view-item hidden" style="padding: 24px; max-width: 800px; margin: 0 auto;">
          <div style="background: white; padding: 40px; border-radius: 16px; border: 1px solid var(--glass-border); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);">
              <div style="text-align: center; margin-bottom: 32px;">
                  <img src="../../assets/images/omnis-logo-white.png" alt="Omnis Logo" style="height: 48px; filter: invert(1); margin-bottom: 16px;">
                  <h1 style="font-size: 28px; font-weight: 800; margin: 0; color: #1e293b;">Fleetrack Dashboard</h1>
                  <p style="color: #64748b; font-size: 14px; margin-top: 8px;">Enterprise Telemetry & Breakdown Management</p>
              </div>

              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
                  <div style="padding: 20px; background: #f8fafc; border-radius: 12px; border: 1px solid #e2e8f0;">
                      <h3 style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: #64748b; margin-top: 0;">Software Information</h3>
                      <div style="margin-top: 12px;">
                          <div style="display: flex; justify-content: space-between; padding: 4px 0; font-size: 13px;">
                              <span style="color: #64748b;">Build Version</span>
                              <span style="font-weight: 700; color: #1e293b;">v2.4.5-STABLE</span>
                          </div>
                          <div style="display: flex; justify-content: space-between; padding: 4px 0; font-size: 13px;">
                              <span style="color: #64748b;">Core Engine</span>
                              <span style="font-weight: 700; color: #1e293b;">Omnis OS v4.1</span>
                          </div>
                          <div style="display: flex; justify-content: space-between; padding: 4px 0; font-size: 13px;">
                              <span style="color: #64748b;">Update Channel</span>
                              <span style="font-weight: 700; color: #2563eb;">Enterprise Early Access</span>
                          </div>
                      </div>
                  </div>

                  <div style="padding: 20px; background: #f8fafc; border-radius: 12px; border: 1px solid #e2e8f0;">
                      <h3 style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: #ef4444; margin-top: 0;">Security Patches</h3>
                      <div style="margin-top: 12px;">
                          <div style="display: flex; gap: 8px; align-items: start; margin-bottom: 8px;">
                              <div style="width: 6px; height: 6px; border-radius: 50%; background: #ef4444; margin-top: 6px;"></div>
                              <div style="font-size: 12.5px;">
                                  <div style="font-weight: 700; color: #1e293b;">CSP Hardening 2026.03</div>
                                  <div style="color: #64748b; font-size: 11px;">Mitigates unauthorized script injection risk.</div>
                              </div>
                          </div>
                          <div style="display: flex; gap: 8px; align-items: start; margin-bottom: 8px;">
                              <div style="width: 6px; height: 6px; border-radius: 50%; background: #ef4444; margin-top: 6px;"></div>
                              <div style="font-size: 12.5px;">
                                  <div style="font-weight: 700; color: #1e293b;">XSS Prevention Patch</div>
                                  <div style="color: #64748b; font-size: 11px;">Secured breakdown note input fields.</div>
                              </div>
                          </div>
                          <div style="display: flex; gap: 8px; align-items: start;">
                              <div style="width: 6px; height: 6px; border-radius: 50%; background: #ef4444; margin-top: 6px;"></div>
                              <div style="font-size: 12.5px;">
                                  <div style="font-weight: 700; color: #1e293b;">Session Encryption v3</div>
                                  <div style="color: #64748b; font-size: 11px;">Upgraded local storage encryption keys.</div>
                              </div>
                          </div>
                      </div>
                  </div>
              </div>

              <div style="margin-top: 32px; padding-top: 24px; border-top: 1px solid #e2e8f0; text-align: center; color: #94a3b8; font-size: 11px;">
